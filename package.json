{
  "name": "dev.dose.steam",
  "version": "2.0.0",
  "description": "Indexes installed Steam games in the background and makes them launchable from the Asyar search.",
  "repository": {
    "type": "git",
    "url": "https://github.com/dose-dot-dev/asyar-steam-extension.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "publish": "asyar publish",
    "link": "asyar link",
    "test": "vitest",
    "test:run": "vitest run",
    "package": "npm run build && zip -r extension.zip dist manifest.json"
  },
  "dependencies": {
    "asyar-sdk": "^4.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
